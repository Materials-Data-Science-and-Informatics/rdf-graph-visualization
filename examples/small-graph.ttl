schema:isAccessibleForFree "true"^^xsd:boolean ;
schema:license <https://creativecommons.org/licenses/by-sa/3.0/> ;
schema:name "Data base of timely, vertically, and horizontally highly resolved dispersal, stability, and drift distance of passively drifting particles in the Baltic Sea with the Kiel Baltic Sea Ice-Ocean Model (BSIOM)" ;
schema:publisher [ ] ;
schema:size <http://purls.helmholtz-metadaten.de/helmholtzkg_0006005> ;
schema:url <https://doi.pangaea.de/10.1594/PANGAEA.883821> .


